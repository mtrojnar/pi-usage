{
  "name": "pi-usage",
  "version": "0.1.0",
  "description": "Usage limit checker for pi coding agent — shows Codex, Anthropic, Copilot, and OpenCode Go limits at startup",
  "license": "MIT",
  "author": "timm-u and Michał Trojnara",
  "authors": [
    {
      "name": "timm-u",
      "url": "https://github.com/timm-u"
    },
    {
      "name": "Michał Trojnara",
      "url": "https://github.com/mtrojnar"
    }
  ],
  "type": "module",
  "main": "index.ts",
  "exports": {
    ".": "./index.ts"
  },
  "files": [
    "index.ts",
    "src",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "pi",
    "pi-package",
    "pi-extension",
    "usage",
    "rate-limits",
    "codex",
    "anthropic",
    "claude",
    "copilot",
    "github-copilot",
    "opencode",
    "opencode-go",
    "monitoring"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/mtrojnar/pi-usage.git"
  },
  "homepage": "https://github.com/mtrojnar/pi-usage",
  "bugs": {
    "url": "https://github.com/mtrojnar/pi-usage/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "scripts": {
    "check": "tsc --noEmit",
    "test": "npx tsx --test index.test.ts"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": ">=0.80.2 <1",
    "@earendil-works/pi-coding-agent": ">=0.80.2 <1",
    "@earendil-works/pi-tui": ">=0.80.2 <1",
    "@types/node": "^24.3.0",
    "typescript": "^5.7.3"
  }
}
